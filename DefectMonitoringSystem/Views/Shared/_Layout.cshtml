<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - MyApp</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <div class="wrapper">

        <!-- Sidebar -->
        <div class="sidebar">
            <h2>MyApp</h2>
            <ul>
                <li class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")">
                    <a asp-controller="Home" asp-action="Index">Dashboard</a>
                </li>

                <li class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Reports" ? "active" : "")">
                    <a asp-controller="Reports" asp-action="Index">Reports</a></li>

                <li class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Machines" ? "active" : "")">
                    <a asp-controller="Machines" asp-action="Index">Machines</a>
                </li>

                <li class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Settings" ? "active" : "")">
                    <a asp-controller="Settings" asp-action="Index">Settings</a>
                </li>
            </ul>
        </div>

        <!-- Main Content -->
        <div class="main-content">
            @RenderBody()
        </div>

    </div>
</body>
</html>